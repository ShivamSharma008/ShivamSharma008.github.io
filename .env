# ──────────────────────────────────────────────
# Shivam Project – Runtime Configuration
# ──────────────────────────────────────────────

# Browser mode: true = invisible (CI), false = visible (dev/debug)
HEADLESS=false

# Base URL for the application under test
BASE_URL=https://practicetestautomation.com

# Default timeout in milliseconds
DEFAULT_TIMEOUT=30000

# Browser viewport
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=720

# Parallel workers (set to 1 to disable parallel)
PARALLEL_WORKERS=1

# Screenshot on every step (true/false)
SCREENSHOT_ON_STEP=true

# Video recording (true/false)
VIDEO_RECORDING=true

